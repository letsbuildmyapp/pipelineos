# Public Firebase config — NEVER put secrets in VITE_* (they bundle to browser)
VITE_FB_API_KEY=demo-api-key
VITE_FB_AUTH_DOMAIN=demo-pipelineos.firebaseapp.com
VITE_FB_PROJECT_ID=demo-pipelineos
VITE_FB_STORAGE_BUCKET=demo-pipelineos.appspot.com
VITE_FB_MSG_SENDER_ID=0
VITE_FB_APP_ID=demo

# Set to "false" to skip emulator connection (use real Firebase)
VITE_USE_EMULATOR=true
